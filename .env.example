ADAPTER_HOST=0.0.0.0
ADAPTER_PORT=8000
ADAPTER_NAMESPACE=agentis
ADAPTER_NAMESPACE_PREFIX=Task
ADAPTER_WORKTREE_ROOT=/var/www/agentiscraft
ADAPTER_MAIN_DIR=/var/www/agentis-kubernetes-adapter
ADAPTER_APP_HOST=
# Address reachable by the agent runtime (e.g. the opencode pod) for /api-internal callbacks.
ADAPTER_PUBLIC_URL=http://localhost:8000
# Agentis passive WebSocket broker. Agentis run-dev uses PASSIVE_ADAPTER_WS_PORT or LISTEN_PORT+1.
AGENTIS_WS_ENDPOINT=ws://127.0.0.1:8892/api/adapters/passive/ws
AGENTIS_ADAPTER_ID=dev-opencode
AGENTIS_WS_HEARTBEAT_INTERVAL=30
AGENTIS_WS_RECONNECT_INITIAL_DELAY=1
AGENTIS_WS_RECONNECT_MAX_DELAY=30
AGENTIS_WS_RECONNECT_MAX_ATTEMPTS=0
AGENTIS_ENDPOINT=http://127.0.0.1:8891
AGENTIS_TOKEN=dev-executor-shared-token
ADAPTER_MANIFEST_PATH=/var/www/agentis-kubernetes-adapter/kubernetes/opencode.yaml
ADAPTER_LOG_LEVEL=info

DOCKER_IMAGE=agentis-kubernetes-adapter:latest
PUSH_IMAGE=0
K8S_NAMESPACE=agentis-adapter
K8S_DEPLOYMENT_NAME=agentis-kubernetes-adapter
K8S_SERVICE_NAME=agentis-kubernetes-adapter
K8S_INGRESS_HOST=
CONTAINER_PORT=8000
